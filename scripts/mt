#!/bin/bash
# MemoryThreads CLI wrapper. Installed to a PATH dir by install.sh (or via `npm link`).
SCRIPT_DIR="$HOME/.claude/memory-server/scripts"
DB_PATH="$HOME/.claude/memory-server/data/memory.db"

case "$1" in
  launch)
    if [ "$2" = "tmux" ]; then
      exec node "$SCRIPT_DIR/mt-launch-tmux.cjs"
    else
      exec node "$SCRIPT_DIR/mt-launch.cjs"
    fi
    ;;
  browse)
    exec node "$SCRIPT_DIR/mt-browse.cjs"
    ;;
  doctor)
    exec node "$SCRIPT_DIR/doctor.cjs"
    ;;
  status)
    sqlite3 "$DB_PATH" "
      SELECT 'turns          ' || COUNT(*) FROM turns
      UNION ALL SELECT 'threads        ' || COUNT(*) FROM threads
      UNION ALL SELECT 'tool_uses      ' || COUNT(*) FROM tool_uses
      UNION ALL SELECT 'summaries      ' || COUNT(*) FROM summaries
      UNION ALL SELECT 'docs           ' || COUNT(*) FROM docs
      UNION ALL SELECT 'bookmarks      ' || COUNT(*) FROM saved_threads
      UNION ALL SELECT 'turns last 4h  ' || COUNT(*) FROM turns WHERE timestamp > datetime('now','-4 hours')
      UNION ALL SELECT 'turns last 24h ' || COUNT(*) FROM turns WHERE timestamp > datetime('now','-24 hours');
    "
    echo ""
    echo "DB size:    $(du -sh "$DB_PATH" 2>/dev/null | awk '{print $1}')"
    echo "Worker PID: $(cat "$HOME/.claude/memory-server/worker.pid" 2>/dev/null || echo 'NOT RUNNING')"
    echo "Last ingest: $(tail -50 "$HOME/.claude/memory-server/logs/worker.log" 2>/dev/null | grep -E 'Ingestion complete|Stored.*turns' | tail -1 | cut -d']' -f1 | tr -d '[')"
    ;;
  ""|help|--help|-h)
    echo "MemoryThreads CLI"
    echo ""
    echo "Usage: mt <command>"
    echo ""
    echo "Commands:"
    echo "  launch        Interactive picker for SAVED bookmarks (resumes the thread)"
    echo "  launch tmux   Same picker, but opens the thread INSIDE tmux (live + joinable from phone)"
    echo "  browse        TUI to browse ALL threads (sortable, filterable by project)"
    echo "  status        DB stats, worker status, recent activity"
    echo "  doctor        Full health check (worker, backlog, wiring, embeddings)"
    echo "  help          Show this help"
    ;;
  *)
    echo "Unknown command: $1" >&2
    echo "Run 'mt help' for usage" >&2
    exit 1
    ;;
esac
